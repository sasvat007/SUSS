# Application
APP_NAME=CapitalSense
APP_ENV=development
DEBUG=True

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/capitalsense

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Hashing / Encryption
FIELD_ENCRYPTION_KEY=your-field-level-encryption-key-32-bytes!

# ML Backend
ML_BACKEND_URL=http://localhost:8001
ML_BACKEND_API_KEY=ml-backend-api-key

# Setu API
SETU_CLIENT_ID=your_setu_client_id
SETU_CLIENT_SECRET=your_setu_client_secret
SETU_BASE_URL=https://prod.setu.co/api

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Tesseract (Windows path example — update as needed)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
